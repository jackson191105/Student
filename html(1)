<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Student Management</title>
    <style>
        body { font-family: Arial, sans-serif; padding: 20px; background: #f4f4f4; }
        .card { background: #fff; padding: 20px; border-radius: 8px; max-width: 400px; margin-bottom: 20px; box-shadow: 0 0 10px rgba(0,0,0,0.1); }
        table { width: 100%; border-collapse: collapse; margin-bottom: 20px; }
        th, td { padding: 10px; text-align: left; }
        th { background: #1a3c6d; color: white; }
        button { padding: 5px 10px; margin-right: 5px; cursor: pointer; }
        .edit-btn { background: #ffc107; border: none; color: #fff; }
        .delete-btn { background: #dc3545; border: none; color: #fff; }
    </style>
</head>
<body>

<div class="card">
    <h3>Add / Update Student</h3>
    <form id="student-form">
        <input type="text" id="name" placeholder="Student Name" required>
        <input type="text" id="roll" placeholder="Roll Number" required>
        <input type="text" id="course" placeholder="Course" required>
        <input type="email" id="email" placeholder="Email" required>
        <select id="gender" required style="width: 100%; margin: 10px 0; padding: 8px;">
            <option value="">Select Gender</option>
            <option value="Boy">Boy</option>
            <option value="Girl">Girl</option>
        </select>
        <button type="submit" id="save-btn" style="background: #1a3c6d; color: white; width: 100%; padding: 10px; border: none; cursor: pointer;">Save Student</button>
    </form>
</div>

<hr>

<h3>Boys List</h3>
<table border="1">
    <thead>
        <tr><th>Name</th><th>Roll</th><th>Course</th><th>Email</th><th>Actions</th></tr>
    </thead>
    <tbody id="boys-list"></tbody>
</table>

<h3>Girls List</h3>
<table border="1">
    <thead>
        <tr><th>Name</th><th>Roll</th><th>Course</th><th>Email</th><th>Actions</th></tr>
    </thead>
    <tbody id="girls-list"></tbody>
</table>

<script>
let students = [];
let editIndex = -1;

const form = document.getElementById('student-form');
const boysList = document.getElementById('boys-list');
const girlsList = document.getElementById('girls-list');

form.addEventListener('submit', function(e){
    e.preventDefault();

    const name = document.getElementById('name').value.trim();
    const roll = document.getElementById('roll').value.trim();
    const course = document.getElementById('course').value.trim();
    const email = document.getElementById('email').value.trim();
    const gender = document.getElementById('gender').value;

    if(editIndex >= 0){
        // Update existing student
        students[editIndex] = { name, roll, course, email, gender };
        editIndex = -1;
        document.getElementById('save-btn').textContent = 'Save Student';
    } else {
        // Add new student
        students.push({ name, roll, course, email, gender });
    }

    form.reset();
    renderLists();
});

function renderLists(){
    boysList.innerHTML = '';
    girlsList.innerHTML = '';

    students.forEach((student, index) => {
        const row = `<tr>
            <td>${student.name}</td>
            <td>${student.roll}</td>
            <td>${student.course}</td>
            <td>${student.email}</td>
            <td>
                <button class="edit-btn" onclick="editStudent(${index})">Edit</button>
                <button class="delete-btn" onclick="deleteStudent(${index})">Delete</button>
            </td>
        </tr>`;

        if(student.gender === 'Boy') boysList.innerHTML += row;
        else if(student.gender === 'Girl') girlsList.innerHTML += row;
    });
}

function editStudent(index){
    const student = students[index];
    document.getElementById('name').value = student.name;
    document.getElementById('roll').value = student.roll;
    document.getElementById('course').value = student.course;
    document.getElementById('email').value = student.email;
    document.getElementById('gender').value = student.gender;

    editIndex = index;
    document.getElementById('save-btn').textContent = 'Update Student';
}

function deleteStudent(index){
    if(confirm('Are you sure you want to delete this student?')){
        students.splice(index, 1);
        renderLists();
    }
}
</script>

</body>
</html>
