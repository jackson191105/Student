#student-table td {
    position: relative;
    overflow: visible;
}

.menu-container {
    position: relative;
    display: inline-block;
}

.dots-btn {
    cursor: pointer;
    font-size: 22px;
    background: none;
    border: none;
    padding: 0 10px;
    color: #1a3c6d;
    line-height: 1;
}

.requirements-dropdown {
    display: none;
    position: absolute;
    top: 100%; /* Appears below the dots */
    left: 0;
    background-color: #ffffff;
    min-width: 180px;
    box-shadow: 0px 4px 12px rgba(0,0,0,0.15);
    z-index: 999;
    border: 1px solid #ddd;
    border-radius: 5px;
    padding: 12px;
    text-align: left;
}

.requirements-dropdown.show {
    display: block;
}

.requirements-dropdown p {
    margin: 8px 0;
    font-size: 14px;
    border-bottom: 1px solid #eee; /* Fixed line */
    padding-bottom: 4px;
}
